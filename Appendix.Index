private void ڕێکخستنی_داتاگرید()
{
    try
    {
        if (dataGridView1.Columns.Count > 0)
        {
            if (dataGridView1.Columns.Contains("Id"))
            {
                dataGridView1.Columns["Id"].HeaderText = "ژمارە";
                dataGridView1.Columns["Id"].Width = 50;
            }
            if (dataGridView1.Columns.Contains("FuelType"))
            {
                dataGridView1.Columns["FuelType"].HeaderText = "جۆری سووتەمەنی";
                dataGridView1.Columns["FuelType"].Width = 150;
            }
            if (dataGridView1.Columns.Contains("Quantity"))
            {
                dataGridView1.Columns["Quantity"].HeaderText = "بڕ";
                dataGridView1.Columns["Quantity"].Width = 100;
                dataGridView1.Columns["Quantity"].DefaultCellStyle.Format = "N0";
                dataGridView1.Columns["Quantity"].DefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleRight;
            }
            if (dataGridView1.Columns.Contains("PricePerLiter"))
            {
                dataGridView1.Columns["PricePerLiter"].HeaderText = "نرخ";
                dataGridView1.Columns["PricePerLiter"].Width = 100;
                dataGridView1.Columns["PricePerLiter"].DefaultCellStyle.Format = "N0";
                dataGridView1.Columns["PricePerLiter"].DefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleRight;
            }
            if (dataGridView1.Columns.Contains("Supplier"))
            {
                dataGridView1.Columns["Supplier"].HeaderText = "دابینکەر";
                dataGridView1.Columns["Supplier"].Width = 150;
            }
            if (dataGridView1.Columns.Contains("EntryDate"))
            {
                dataGridView1.Columns["EntryDate"].HeaderText = "بەروار";
                dataGridView1.Columns["EntryDate"].Width = 120;
            }
        }
    }
    catch (Exception ex)
    {
        MessageBox.Show($"هەڵە لە ڕێکخستنی داتاگرید: {ex.Message}", "هەڵە");
    }
}

private void بارکردنی_زانیاری_سووتەمەنی()
{
    try
    {
        using (SqlConnection con = new SqlConnection(connectionString))
        {
            con.Open();
            string query = "SELECT * FROM Products WHERE Id = @Id";
            SqlCommand cmd = new SqlCommand(query, con);
            cmd.Parameters.AddWithValue("@Id", selectedProductId);

            SqlDataReader reader = cmd.ExecuteReader();
            if (reader.Read())
            {
                banzin.Text = reader["FuelType"].ToString();
                txtQuantity.Text = reader["Quantity"].ToString();
                txtPrice.Text = reader["PricePerLiter"].ToString();
                txtSupplier.Text = reader["Supplier"].ToString();
                dateEntry.Value = Convert.ToDateTime(reader["EntryDate"]);
            }
            reader.Close();
        }
    }
    catch (Exception ex)
    {
        MessageBox.Show($"هەڵە لە بارکردنی زانیاری: {ex.Message}");
    }
}

private void btnAdd_Click_1(object sender, EventArgs e)
{
    if (!پشکنینی_بوارەکان()) return;

    using (SqlConnection con = new SqlConnection(connectionString))
    {
        try
        {
            con.Open();

            if (selectedProductId == 0)
            {
                string query = @"INSERT INTO Products (FuelType, Quantity, PricePerLiter, Supplier, EntryDate) 
                               VALUES (@FuelType, @Quantity, @PricePerLiter, @Supplier, @EntryDate)";

                SqlCommand cmd = new SqlCommand(query, con);
                cmd.Parameters.AddWithValue("@FuelType", banzin.Text);
                cmd.Parameters.AddWithValue("@Quantity", decimal.Parse(txtQuantity.Text));
                cmd.Parameters.AddWithValue("@PricePerLiter", decimal.Parse(txtPrice.Text));
                cmd.Parameters.AddWithValue("@Supplier", txtSupplier.Text);
                cmd.Parameters.AddWithValue("@EntryDate", dateEntry.Value);

                int result = cmd.ExecuteNonQuery();
                if (result > 0)
                {
                    MessageBox.Show("سووتەمەنی بە سەرکەوتوویی زیادکرا", "سەرکەوتوو");
                    بارکردنی_داتاکان();
                    پاکردنەوەی_بوارەکان();
                }
            }
            else
            {
                string query = @"UPDATE Products 
                               SET FuelType = @FuelType,
                                   Quantity = @Quantity,
                                   PricePerLiter = @PricePerLiter,
                                   Supplier = @Supplier,
                                   EntryDate = @EntryDate
                               WHERE Id = @Id";

                SqlCommand cmd = new SqlCommand(query, con);
                cmd.Parameters.AddWithValue("@Id", selectedProductId);
                cmd.Parameters.AddWithValue("@FuelType", banzin.Text);
                cmd.Parameters.AddWithValue("@Quantity", decimal.Parse(txtQuantity.Text));
                cmd.Parameters.AddWithValue("@PricePerLiter", decimal.Parse(txtPrice.Text));
                cmd.Parameters.AddWithValue("@Supplier", txtSupplier.Text);
                cmd.Parameters.AddWithValue("@EntryDate", dateEntry.Value);

                int result = cmd.ExecuteNonQuery();
                if (result > 0)
                {
                    MessageBox.Show("سووتەمەنی بە سەرکەوتوویی نوێکرایەوە", "سەرکەوتوو");
                    بارکردنی_داتاکان();
                    پاکردنەوەی_بوارەکان();
                }
            }
        }
        catch (SqlException sqlEx)
        {
            MessageBox.Show($"هەڵەی داتابەیس: {sqlEx.Message}", "هەڵە");
        }
        catch (Exception ex)
        {
            MessageBox.Show($"هەڵە: {ex.Message}", "هەڵە");
        }
    }
}

