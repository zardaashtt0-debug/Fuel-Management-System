        private void CheckDatabaseTables()
        {
            try
            {
                using (SqlConnection con = new SqlConnection(connectionString))
                {
                    con.Open();
                   string query = @"
                    SELECT 
                        CASE 
                            WHEN OBJECT_ID('Products') IS NOT NULL THEN '✅ Products'
                            ELSE '❌ Products'
                        END as 'خشتەی ١',
                        CASE 
                            WHEN OBJECT_ID('Sales') IS NOT NULL THEN '✅ Sales'
                            ELSE '❌ Sales'
                        END as 'خشتەی ٢'";

                    SqlCommand cmd = new SqlCommand(query, con);
                    SqlDataReader reader = cmd.ExecuteReader();

                    if (reader.Read())
                    {
                        MessageBox.Show($"پشکنینی خشتەکان:\n\n{reader[0]}\n{reader[1]}",
         "پشکنین", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                    reader.Close();
            }
            catch (Exception ex)
            {
                MessageBox.Show("هەڵە لە پشکنینی خشتەکان: " + ex.Message);
         
