public LoginForm(string userType)
{
    InitializeComponent();
    this.userType = userType;
    SetupFormForUserType();
}
private void SetupFormForUserType()
{
    if (userType == "Admin")
    {
        Text = "چوونەژوورەوەی بەڕێوەبەر";
        lblTitle.Text = "چوونەژوورەوەی بەڕێوەبەر 👑";
        lblTitle.ForeColor = Color.FromArgb(220, 53, 69);
        btnLogin.BackColor = Color.FromArgb(220, 53, 69);
        lblInfo.Text = "تکایە ناوی بەکارهێنەر و وشەی نهێنی بەڕێوەبەر بنووسە";
    }
    else
    {
        Text = "چوونەژوورەوەی بەکارهێنەر";
        lblTitle.Text = "چوونەژوورەوەی بەکارهێنەر 👤";
        lblTitle.ForeColor = Color.FromArgb(40, 167, 69);
        btnLogin.BackColor = Color.FromArgb(40, 167, 69);
        lblInfo.Text = "تکایە ناوی بەکارهێنەر و وشەی نهێنی بەکارهێنەر بنووسە";
    }
}

private void btnLogin_Click_1(object sender, EventArgs e)
{
    if (string.IsNullOrWhiteSpace(txtUsername.Text) ||
        string.IsNullOrWhiteSpace(txtPassword.Text))
    {
        MessageBox.Show("تكایە ناوی بەکارهێنەر و وشەی نهێنی پڕبکەرەوە");
        return;
    }

    bool result = TryDatabaseLogin();
}

private bool TryDatabaseLogin()
{
    try
    {
        using (SqlConnection con = new SqlConnection(connectionString))
        {
            con.Open();

            if (userType != "Admin")
            {
                string userQuery = "SELECT COUNT(*) FROM Users WHERE Username = @u AND Password = @p";

                SqlCommand cmdUser = new SqlCommand(userQuery, con);
                cmdUser.Parameters.AddWithValue("@u", txtUsername.Text.Trim());
                cmdUser.Parameters.AddWithValue("@p", txtPassword.Text.Trim());

                int userCount = (int)cmdUser.ExecuteScalar();

                if (userCount > 0)
                {
                    ShowSuccess();
                    return true;
                }
                else
                {
                    string checkUserQuery = "SELECT COUNT(*) FROM Users WHERE Username = @u";
                    SqlCommand checkCmd = new SqlCommand(checkUserQuery, con);
                    checkCmd.Parameters.AddWithValue("@u", txtUsername.Text.Trim());

                    int userExists = (int)checkCmd.ExecuteScalar();

                    if (userExists > 0)
                    {
                        MessageBox.Show("❌ وشەی نهێنی هەڵە!");
                    }
                    else
                    {
                        MessageBox.Show("❌ ناوی بەکارهێنەر نەدۆزرایەوە!");
                    }
                    return false;
                }
            }
            else
            {
                string[] adminTables = { "AdminTable", "AdminTb", "admin" };

                foreach (string table in adminTables)
                {
                    string q = $"SELECT COUNT(*) FROM {table} WHERE [user]=@u AND [pass]=@p";
                    SqlCommand cmdAdmin = new SqlCommand(q, con);
                    cmdAdmin.Parameters.AddWithValue("@u", txtUsername.Text);
                    cmdAdmin.Parameters.AddWithValue("@p", txtPassword.Text);

                    if ((int)cmdAdmin.ExecuteScalar() > 0)
                    {
                        MessageBox.Show($"✔ لە خشتەکەوە وەک Admin چووەتە ژوورەوە: {table}");
                        ShowSuccess();
                        return true;
                    }
                }

                MessageBox.Show("❌ زانیاری نادرووستە (Admin) !");
                return false;
            }
        }
    }
    catch (Exception ex)
    {
        MessageBox.Show($"هەڵە لە پەیوەندی بە بنکەدراوەوە:\n{ex.Message}");
        return false;
    }
}

private void ShowSuccess()
{
    string msg = userType == "Admin"
        ? "بەخێربێیت ئەدمین 👑"
        : "چوونەژوورەوە سەرکەوتوو بوو 👤";

    MessageBox.Show(msg);

    Dashboard dash = new Dashboard(userType);
    dash.Show();
    Hide();
}

private void CheckAdminTableData()
{
    try
    {
        using (SqlConnection con = new SqlConnection(connectionString))
        {
            con.Open();
            string q = "SELECT Id, [user], [pass] FROM AdminTable";
            SqlCommand cmd = new SqlCommand(q, con);
            SqlDataReader dr = cmd.ExecuteReader();

            string msg = "📌 داتاکانی خشتەی AdminTable:\n\n";
            bool has = false;

            while (dr.Read())
            {
                msg += $"ID: {dr["Id"]} | User: {dr["user"]} | Pass: {dr["pass"]}\n";
                has = true;
            }
            dr.Close();

            if (has) MessageBox.Show(msg);
            else if (MessageBox.Show("❌ داتا نیە — زیاد بکرێت؟", "", MessageBoxButtons.YesNo) == DialogResult.Yes)
                AddDefaultAdminData();
        }
    catch (Exception ex)
    {
        MessageBox.Show($"❌ هەڵە لە دەستکەوتن بە داتا: {ex.Message}");
    }
}

private void AddDefaultAdminData()
{
    try
    {
        using (SqlConnection con = new SqlConnection(connectionString))
        {
            con.Open();
            string q = "INSERT INTO AdminTable ([user],[pass]) VALUES ('admin','123456')";
            SqlCommand cmd = new SqlCommand(q, con);
            if (cmd.ExecuteNonQuery() > 0)
                MessageBox.Show("✨ داتای بنچینەی بەڕێوەبەر زیاد کرا!");
        }
    }
    catch (Exception ex)
    {
        MessageBox.Show($"❌ هەڵە لە زیادکردنی داتا: {ex.Message}");
    }
}
