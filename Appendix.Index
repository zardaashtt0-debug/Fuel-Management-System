private void txtSearch_TextChanged(object sender, EventArgs e)
{
    SearchUsers(txtSearch.Text);
}

private void SearchUsers(string searchText)
{
    if (dataGridViewUsers.DataSource is DataTable dt)
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            dt.DefaultView.RowFilter = "";
        }
        else
        {
            string filter = $"[ناوی بەکارهێنەر] LIKE '%{searchText}%'";
            dt.DefaultView.RowFilter = filter;
        }
        UpdateStatistics(dt);
    }
}

private void btnDeleteUser_Click_1(object sender, EventArgs e)
{
    if (dataGridViewUsers.CurrentRow != null && dataGridViewUsers.CurrentRow.Index >= 0)
    {
        DataGridViewRow row = dataGridViewUsers.CurrentRow;
        string username = row.Cells["ناوی بەکارهێنەر"].Value?.ToString() ?? "";

        if (string.IsNullOrEmpty(username))
        {
            MessageBox.Show("تکایە بەکارهێنەرێکی دروست هەڵبژێرە!", "هەڵە", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            return;
        }

        DialogResult result = MessageBox.Show(
            $"دڵنیای لە سڕینەوەی بەکارهێنەر '{username}'?",
            "سڕینەوەی بەکارهێنەر",
            MessageBoxButtons.YesNo,
            MessageBoxIcon.Question);

        if (result == DialogResult.Yes)
        {
            if (DeleteUser(username))
            {
                MessageBox.Show("بەکارهێنەر سڕدرایەوە!", "سەرکەوتوو", MessageBoxButtons.OK, MessageBoxIcon.Information);
                LoadAllUsers();
            }
        }
    }
    else
    {
        MessageBox.Show("تکایە بەکارهێنەرێک هەڵبژێرە!", "هەڵە", MessageBoxButtons.OK, MessageBoxIcon.Warning);
    }
}

private bool DeleteUser(string username)
{
    try
    {
        using (SqlConnection con = new SqlConnection(connectionString))
        {
            con.Open();

            if (!CheckTableExists(con, "Users"))
            {
                MessageBox.Show("خشتەی کارمەندان بوونی نیە!", "هەڵە", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return false;
            }

            string query = "DELETE FROM Users WHERE Username = @username";
            SqlCommand cmd = new SqlCommand(query, con);
            cmd.Parameters.AddWithValue("@username", username);
            return cmd.ExecuteNonQuery() > 0;
        }
    }
    catch (Exception ex)
    {
        MessageBox.Show($"هەڵە لە سڕینەوەی بەکارهێنەر: {ex.Message}", "هەڵە", MessageBoxButtons.OK, MessageBoxIcon.Error);
        return false;
    }
}

private void btnResetPassword_Click_1(object sender, EventArgs e)
{
    if (dataGridViewUsers.CurrentRow != null && dataGridViewUsers.CurrentRow.Index >= 0)
    {
        DataGridViewRow row = dataGridViewUsers.CurrentRow;
        string username = row.Cells["ناوی بەکارهێنەر"].Value?.ToString() ?? "";

        if (string.IsNullOrEmpty(username))
        {
            MessageBox.Show("تکایە بەکارهێنەرێکی دروست هەڵبژێرە!", "هەڵە", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            return;
        string newPassword = "123123";

        if (ResetUserPassword(username, newPassword))
        {
            MessageBox.Show($"وشەی نهێنی بۆ '{username}' ڕێکخرایەوە بۆ: {newPassword}", "سەرکەوتوو", MessageBoxButtons.OK, MessageBoxIcon.Information);
            LoadAllUsers();
        }
    }
    else
    {
        MessageBox.Show("تکایە بەکارهێنەرێک هەڵبژێرە!", "هەڵە", MessageBoxButtons.OK, MessageBoxIcon.Warning);
    }
}

private bool ResetUserPassword(string username, string newPassword)
{
    try
    {
        using (SqlConnection con = new SqlConnection(connectionString))
        {
            con.Open();

            if (!CheckTableExists(con, "Users"))
            {
                MessageBox.Show("خشتەی کارمەندان بوونی نیە!", "هەڵە", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return false;
            }

            string query = "UPDATE Users SET Password = @password WHERE Username = @username";
            SqlCommand cmd = new SqlCommand(query, con);
            cmd.Parameters.AddWithValue("@password", newPassword);
            cmd.Parameters.AddWithValue("@username", username);
            return cmd.ExecuteNonQuery() > 0;
        }
    }
    catch (Exception ex)
    {
        MessageBox.Show($"هەڵە لە ڕێکخستنی وشەی نهێنی: {ex.Message}", "هەڵە", MessageBoxButtons.OK, MessageBoxIcon.Error);
        return false;
    }
}

private void btnCheckTables_Click_1(object sender, EventArgs e)
{
    CheckDatabaseTables();
}

private void CheckDatabaseTables()
{
    try
    {
        using (SqlConnection con = new SqlConnection(connectionString))
        {
            con.Open();

            string query = @"
            SELECT 
                name as 'ناوی خشتە',
                CASE 
                    WHEN name = 'Users' THEN (SELECT COUNT(*) FROM Users)
                    ELSE 0
                END as 'ژمارەی بەکارهێنەران'
            FROM sys.tables 
            WHERE name = 'Users'
            ORDER BY name";

            SqlCommand cmd = new SqlCommand(query, con);
            SqlDataReader dr = cmd.ExecuteReader();

            string status = "خشتەکانی بنکەی دراوە:\n\n";
            bool hasTables = false;

            while (dr.Read())
            {
                status += $"• {dr["ناوی خشتە"]} - {dr["ژمارەی بەکارهێنەران"]} بەکارهێنەر\n";
                hasTables = true;
            }
            dr.Close();

            if (!hasTables)
            {
                status += "❌ هیچ خشتەیەک نەدۆزرایەوە!";
            }

            MessageBox.Show(status, "ڕێگای خشتەکان", MessageBoxButtons.OK, MessageBoxIcon.Information);
        }
    }
    catch (Exception ex)
    {
        MessageBox.Show($"هەڵە لە پشکنینی خشتەکان: {ex.Message}", "هەڵە", MessageBoxButtons.OK, MessageBoxIcon.Error);
    }
}

