        private void PrintSingleInvoice(int saleId)
        {
            try
            {
                using (SqlConnection con = new SqlConnection(connectionString))
                {
                    con.Open();

                    string query = @"
                    SELECT Id, FuelType, Quantity, PricePerLiter, TotalAmount, 
                           CustomerName, VehicleNumber, SaleDate 
                    FROM Sales WHERE Id = @SaleId";

                    SqlCommand cmd = new SqlCommand(query, con);
                    cmd.Parameters.AddWithValue("@SaleId", saleId);

                    SqlDataReader reader = cmd.ExecuteReader();

                    if (reader.Read())
                    {
                        PrintDocument invoiceDoc = new PrintDocument();
                        invoiceDoc.PrintPage += (s, e) => PrintInvoicePage(s, e, reader);

                        PrintPreviewDialog preview = new PrintPreviewDialog();
                        preview.Document = invoiceDoc;
                        preview.Text = "پێشبینینی فاتورە";
                        preview.ShowDialog();
                    }
                    reader.Close();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"هەڵە لە چاپکردنی فاتورە: {ex.Message}");
            }
        }

        private void PrintInvoicePage(object sender, PrintPageEventArgs e, SqlDataReader reader)
        {
            Graphics g = e.Graphics;
            Font titleFont = new Font("Arial", 20, FontStyle.Bold);
            Font headerFont = new Font("Arial", 14, FontStyle.Bold);
            Font normalFont = new Font("Arial", 12);

            float yPos = 50;
            float center = e.MarginBounds.Width / 2;

            string title = "فاتورەی فرۆشتن";
            g.DrawString(title, titleFont, Brushes.DarkBlue, center - 100, yPos);
            yPos += 40;

            g.DrawString("شوێنی وێستگەی سووتەمەنی", headerFont, Brushes.Black, center - 120, yPos);
            yPos += 25;
            g.DrawString("تەلەفۆن: ٠٧٧٠ ١٢٣ ٤٥٦٧", normalFont, Brushes.Black, center - 80, yPos);
            yPos += 40;

            g.DrawLine(Pens.Black, 50, yPos, e.MarginBounds.Width - 50, yPos);
            yPos += 20;

            string fuelType = reader["FuelType"].ToString();
            decimal quantity = Convert.ToDecimal(reader["Quantity"]);
            decimal price = Convert.ToDecimal(reader["PricePerLiter"]);
            decimal total = Convert.ToDecimal(reader["TotalAmount"]);
            string customer = reader["CustomerName"].ToString();
            string vehicle = reader["VehicleNumber"].ToString();
            DateTime saleDate = Convert.ToDateTime(reader["SaleDate"]);

            g.DrawString("ناوی کڕیار:", headerFont, Brushes.Black, 80, yPos);
            g.DrawString(customer, normalFont, Brushes.Black, 300, yPos);
            yPos += 35;

            g.DrawString("ژمارەی سەیارە:", headerFont, Brushes.Black, 80, yPos);
            g.DrawString(vehicle, normalFont, Brushes.Black, 300, yPos);
            yPos += 35;

            g.DrawString("جۆری سووتەمەنی:", headerFont, Brushes.Black, 80, yPos);
            g.DrawString(fuelType, normalFont, Brushes.Black, 300, yPos);
            yPos += 35;

            g.DrawString("بڕ (لیتر):", headerFont, Brushes.Black, 80, yPos);
            g.DrawString(quantity.ToString("N2"), normalFont, Brushes.Black, 300, yPos);
            yPos += 35;

            g.DrawString("نرخ:", headerFont, Brushes.Black, 80, yPos);
            g.DrawString(price.ToString("N2") + " دینار", normalFont, Brushes.Black, 300, yPos);
            yPos += 35;

            g.DrawString("کۆی گشتی:", headerFont, Brushes.Black, 80, yPos);
            g.DrawString(total.ToString("N2") + " دینار", normalFont, Brushes.Black, 300, yPos);
            yPos += 35;

            g.DrawString("بەروار:", headerFont, Brushes.Black, 80, yPos);
            g.DrawString(saleDate.ToString("yyyy/MM/dd HH:mm"), normalFont, Brushes.Black, 300, yPos);
            yPos += 35;

            g.DrawString("ژمارەی فاتورە:", headerFont, Brushes.Black, 80, yPos);
            g.DrawString(reader["Id"].ToString(), normalFont, Brushes.Black, 300, yPos);
            yPos += 50;

            g.DrawString("سوپاس بۆ داواکاریەکەت! ✨", headerFont, Brushes.DarkGreen, center - 120, yPos);
            yPos += 40;
            g.DrawString("واژۆ", headerFont, Brushes.Black, center - 30, yPos);
            yPos += 20;
            g.DrawLine(Pens.Black, center - 50, yPos, center + 50, yPos);
        }

        private void dataGridView1_CellContentClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex >= 0 && e.ColumnIndex >= 0)
            {
                int saleId = Convert.ToInt32(dataGridView1.Rows[e.RowIndex].Cells["ژمارە"].Value);
                PrintSingleInvoice(saleId);
            }
        }
    }
