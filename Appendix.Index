        private void FeedbackForm_Load(object sender, EventArgs e)
        {
            dateFeedback.Value = DateTime.Now;
            comboRating.SelectedIndex = 4;
        }

        private void btnSubmit_Click(object sender, EventArgs e)
        {
            if (!پشکنینی_بوارەکان()) return;

            try
            {

                using (SqlConnection con = new SqlConnection(connectionString))
                {
                    con.Open();
                    دڵنیابوون_لە_بوونی_جدول(con);
                    string query = @"INSERT INTO Feedbacks (CustomerName, Email, Rating, Comment, ProductName, FeedbackDate, IsApproved) 
                                   VALUES (@CustomerName, @Email, @Rating, @Comment, @ProductName, @FeedbackDate, @IsApproved)";

                    SqlCommand cmd = new SqlCommand(query, con);
                    cmd.Parameters.AddWithValue("@CustomerName", txtCustomerName.Text);
                    cmd.Parameters.AddWithValue("@Email", txtEmail.Text);
                    cmd.Parameters.AddWithValue("@Rating", comboRating.SelectedIndex + 1);
                    cmd.Parameters.AddWithValue("@Comment", txtComment.Text);
                    cmd.Parameters.AddWithValue("@ProductName", txtProductName.Text);
                    cmd.Parameters.AddWithValue("@FeedbackDate", dateFeedback.Value);
                    cmd.Parameters.AddWithValue("@IsApproved", 1); 

                    int result = cmd.ExecuteNonQuery();
                    if (result > 0)
                    {
                        MessageBox.Show("سوپاس بۆ فیدباکەکەت! فیدباکەکەت پێداچوونەوەی بۆ دەکرێت.", "سەرکەوتوو");
                        پاکردنەوەی_بوارەکان();
                    }
            catch (Exception ex)
            {
                MessageBox.Show($"هەڵە: {ex.Message}", "هەڵە");
            }
        }
        private bool پشکنینی_بوارەکان()
        {
            if (string.IsNullOrEmpty(txtCustomerName.Text))
            {
                MessageBox.Show("تکایە ناوی خۆت بنووسە", "ئاگاداری");
                txtCustomerName.Focus();
                return false;
            }

            if (string.IsNullOrEmpty(txtComment.Text))
            {
                MessageBox.Show("تکایە بۆچوونی خۆت بنووسە", "ئاگاداری");
                txtComment.Focus();
                return false;
            }

            if (comboRating.SelectedIndex == -1)
            {
                MessageBox.Show("تکایە هەڵسەنگاندن دیاری بکە", "ئاگاداری");
                comboRating.Focus();
                return false;
            }

            return true;
        }
        private void دڵنیابوون_لە_بوونی_جدول(SqlConnection con)
        {
            string checkTableQuery = @"
                IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='Feedbacks' AND xtype='U')
                BEGIN
                    CREATE TABLE Feedbacks (
                        Id INT IDENTITY(1,1) PRIMARY KEY,
                        CustomerName NVARCHAR(100) NOT NULL,
                        Email NVARCHAR(100) NULL,
                        Rating INT NOT NULL,
                        Comment NVARCHAR(500) NOT NULL,
                        ProductName NVARCHAR(100) NULL,
                        FeedbackDate DATETIME NOT NULL,
                        IsApproved BIT DEFAULT 0 NOT NULL
                    )
                END";

            SqlCommand checkCmd = new SqlCommand(checkTableQuery, con);
            checkCmd.ExecuteNonQuery();
        }

        private void پاکردنەوەی_بوارەکان()
        {
            txtCustomerName.Clear();
            txtEmail.Clear();
            txtComment.Clear();
            txtProductName.Clear();
            comboRating.SelectedIndex = 4;
            dateFeedback.Value = DateTime.Now;
            txtCustomerName.Focus();
        }

        private void btnCancel_Click(object sender, EventArgs e)
        {
            this.Close();
        }
    }
