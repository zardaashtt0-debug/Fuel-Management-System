                Label lblUserType = new Label();
                lblUserType.Text = "بەکارهێنەر";
                lblUserType.Font = new Font("Tahoma", 12F, FontStyle.Bold);
                lblUserType.ForeColor = Color.Blue;
                lblUserType.Location = new Point(200, 40);
                lblUserType.Size = new Size(120, 25);
                this.Controls.Add(lblUserType);

                MessageBox.Show("بەخێربێیت! تەنها دەتوانیت فرۆشتن بکەیت.", "بەخێربێیت", MessageBoxButtons.OK, MessageBoxIcon.Information);
