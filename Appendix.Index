private void پاکردنەوەی_بوارەکان()
{
    selectedId = 0;
    selectedProductId = 0;
    banzin.Clear();
    txtQuantity.Clear();
    txtPrice.Clear();
    txtSupplier.Clear();
    dateEntry.Value = DateTime.Now;
    btnAdd.Text = "زیادکردن";
    banzin.Focus();
}

private void dataGridView1_CellClick(object sender, DataGridViewCellEventArgs e)
{
    if (e.RowIndex >= 0)
    {
        try
        {
            DataGridViewRow row = dataGridView1.Rows[e.RowIndex];

            selectedId = Convert.ToInt32(row.Cells[0].Value);
            selectedProductId = selectedId;
            banzin.Text = row.Cells[1].Value?.ToString() ?? "";
            txtQuantity.Text = row.Cells[2].Value?.ToString() ?? "0";
            txtPrice.Text = row.Cells[3].Value?.ToString() ?? "0";
            txtSupplier.Text = row.Cells[4].Value?.ToString() ?? "";

            if (row.Cells[5].Value != null)
                dateEntry.Value = Convert.ToDateTime(row.Cells[5].Value);

            btnAdd.Text = "نوێکردنەوە";
            banzin.Focus();
            banzin.SelectAll();
        }
        catch (Exception ex)
        {
         //   MessageBox.Show($"هەڵە لە بارکردنی داتا: {ex.Message}");
        }
    }
}

private void dataGridView1_CellEnter(object sender, DataGridViewCellEventArgs e)
{

    if (e.RowIndex >= 0)
    {
        try
        {
            DataGridViewRow row = dataGridView1.Rows[e.RowIndex];

            if (dataGridView1.Columns.Count > 0)
            {
                if (dataGridView1.Columns.Contains("Id") && row.Cells["Id"].Value != null)
                    selectedId = Convert.ToInt32(row.Cells["Id"].Value);
                else
                    selectedId = 0;

                selectedProductId = selectedId;

                if (dataGridView1.Columns.Contains("FuelType") && row.Cells["FuelType"].Value != null)
                    banzin.Text = row.Cells["FuelType"].Value.ToString();
                else
                    banzin.Text = "";

                if (dataGridView1.Columns.Contains("Quantity") && row.Cells["Quantity"].Value != null)
                    txtQuantity.Text = row.Cells["Quantity"].Value.ToString();
                else
                    txtQuantity.Text = "0";

                if (dataGridView1.Columns.Contains("PricePerLiter") && row.Cells["PricePerLiter"].Value != null)
                    txtPrice.Text = row.Cells["PricePerLiter"].Value.ToString();
                else
                    txtPrice.Text = "0";

                if (dataGridView1.Columns.Contains("Supplier") && row.Cells["Supplier"].Value != null)
                    txtSupplier.Text = row.Cells["Supplier"].Value.ToString();
                else
                    txtSupplier.Text = "";

                if (dataGridView1.Columns.Contains("EntryDate") && row.Cells["EntryDate"].Value != null)
                    dateEntry.Value = Convert.ToDateTime(row.Cells["EntryDate"].Value);

                btnAdd.Text = "نوێکردنەوە";
            }
        }
        catch (Exception ex)
        {
        //    MessageBox.Show($"هەڵە لە بارکردنی داتا: {ex.Message}");
        }
    }
private void dataGridView1_SelectionChanged_1(object sender, EventArgs e)
{
    if (dataGridView1.SelectedRows.Count > 0)
    {
        DataGridViewRow row = dataGridView1.SelectedRows[0];
        selectedId = Convert.ToInt32(row.Cells["Id"].Value);
