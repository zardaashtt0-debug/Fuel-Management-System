•	Raport Sales 

        public ReportsForm()
        {
            InitializeComponent();
            LoadSalesReport();
            SetupBeautifulDesign();
        }

        private void SetupBeautifulDesign()
        {
            this.BackColor = Color.FromArgb(250, 250, 250);

            dataGridView1.BackgroundColor = Color.White;
            dataGridView1.BorderStyle = BorderStyle.None;
            dataGridView1.EnableHeadersVisualStyles = false;
            dataGridView1.ColumnHeadersDefaultCellStyle.BackColor = Color.FromArgb(255, 193, 7);
            dataGridView1.ColumnHeadersDefaultCellStyle.ForeColor = Color.White;
            dataGridView1.ColumnHeadersDefaultCellStyle.Font = new Font("Arial", 10, FontStyle.Bold);
            dataGridView1.AlternatingRowsDefaultCellStyle.BackColor = Color.FromArgb(255, 248, 225);
        }

        private void LoadSalesReport()
        {
            try
            {
                using (SqlConnection con = new SqlConnection(connectionString))
                {
                    con.Open();

                    string query = @"
                    SELECT 
                        Id as 'ژمارە',
                        FuelType as 'جۆری سووتەمەنی',
                        Quantity as 'بڕی (لیتر)',
                        PricePerLiter as 'نرخی هەر لیترێک',
                        TotalAmount as 'کۆی گشتی',
                        CustomerName as 'ناوی کڕیار',
                        VehicleNumber as 'ژمارەی سەیارە',
                        SaleDate as 'بەرواری فرۆشتن'
                    FROM Sales 
                    ORDER BY SaleDate DESC";

                    SqlDataAdapter adapter = new SqlDataAdapter(query, con);
                    DataTable dt = new DataTable();
                    adapter.Fill(dt);

                    dataGridView1.DataSource = dt;
                    CalculateTotals(dt);
                    UpdateSummaryCards(dt);
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"هەڵە لە بارکردنی ڕاپۆرتەکەدا: {ex.Message}");
                LoadSampleData();
            }
        }

        private void CalculateTotals(DataTable dt)
        {
            decimal totalRevenue = 0;
            decimal totalQuantity = 0;
            int totalTransactions = dt.Rows.Count;

            foreach (DataRow row in dt.Rows)
            {
                if (row["کۆی گشتی"] != DBNull.Value)
                {
                    string totalAmountStr = row["کۆی گشتی"].ToString();
                    if (decimal.TryParse(totalAmountStr, out decimal totalAmount))
                    {
                        totalRevenue += totalAmount;
                    }
                }

                if (row["بڕی (لیتر)"] != DBNull.Value)
                {
                    totalQuantity += Convert.ToDecimal(row["بڕی (لیتر)"]);
                }
            }

            lblTotalRevenue.Text = $"{totalRevenue:N0} دينار";
            lblTotalQuantity.Text = $"{totalQuantity:N0} لیتر";
            lblTotalSales.Text = totalTransactions.ToString();
        }

        private void UpdateSummaryCards(DataTable dt)
        {
            if (dt.Rows.Count == 0) return;

            var fuelStats = dt.AsEnumerable()
                .GroupBy(row => row["جۆری سووتەمەنی"].ToString())
                .Select(g => new
                {
                    FuelType = g.Key,
                    TotalQuantity = g.Sum(row =>
                        row["بڕی (لیتر)"] != DBNull.Value ? Convert.ToDecimal(row["بڕی (لیتر)"]) : 0),
                    TotalRevenue = g.Sum(row =>
                    {
                        if (row["کۆی گشتی"] != DBNull.Value)
                        {
                            string totalAmountStr = row["کۆی گشتی"].ToString();
                            return decimal.TryParse(totalAmountStr, out decimal totalAmount) ? totalAmount : 0;
                        }
                        return 0;
                    })
                })
                .OrderByDescending(x => x.TotalRevenue)
                .ToList();

            panelFuelStats.Controls.Clear();

            int yPos = 10;
            foreach (var stat in fuelStats)
            {
                var fuelPanel = CreateFuelStatPanel(stat.FuelType, stat.TotalQuantity, stat.TotalRevenue, yPos);
                panelFuelStats.Controls.Add(fuelPanel);
                yPos += 70;
            }
        }

        private Panel CreateFuelStatPanel(string fuelType, decimal quantity, decimal revenue, int yPos)
        {
            Panel panel = new Panel();
            panel.Size = new Size(280, 60);
            panel.Location = new Point(10, yPos);
            panel.BackColor = GetFuelColor(fuelType);
            panel.BorderStyle = BorderStyle.FixedSingle;

            Label lblType = new Label();
            lblType.Text = fuelType;
            lblType.Font = new Font("Arial", 10, FontStyle.Bold);
            lblType.ForeColor = Color.White;
            lblType.Location = new Point(10, 5);
            lblType.Size = new Size(150, 20);

            Label lblQty = new Label();
            lblQty.Text = $"{quantity:N0} لتر";
            lblQty.Font = new Font("Arial", 9);
            lblQty.ForeColor = Color.White;
            lblQty.Location = new Point(10, 25);
            lblQty.Size = new Size(120, 15);

            Label lblRev = new Label();
            lblRev.Text = $"{revenue:N0} دينار";
            lblRev.Font = new Font("Arial", 9, FontStyle.Bold);
            lblRev.ForeColor = Color.White;
            lblRev.Location = new Point(10, 40);
            lblRev.Size = new Size(120, 15);

            panel.Controls.Add(lblType);
            panel.Controls.Add(lblQty);
            panel.Controls.Add(lblRev);

            return panel;
        }

        private Color GetFuelColor(string fuelType)
        {
            switch (fuelType.ToLower())
            {
                case string s when s.Contains("بنزين 91"):
                    return Color.FromArgb(255, 193, 7);
                case string s when s.Contains("بنزين 95"):
                    return Color.FromArgb(255, 87, 34);
                case string s when s.Contains("ديزل"):
                    return Color.FromArgb(33, 150, 243);
                default:
                    return Color.FromArgb(156, 39, 176);
            }
        }

        private void LoadSampleData()
        {
            DataTable dt = new DataTable();
            dt.Columns.Add("جۆری سووتەمەنی");
            dt.Columns.Add("بڕی (لیتر)", typeof(decimal));
            dt.Columns.Add("نرخی هەر لیترێک", typeof(decimal));
            dt.Columns.Add("کۆی گشتی", typeof(decimal));
            dt.Columns.Add("ناوی کڕیار");
            dt.Columns.Add("ژمارەی سەیارە");
            dt.Columns.Add("بەرواری فرۆشتن", typeof(DateTime));

           

            dataGridView1.DataSource = dt;
            CalculateTotals(dt);
            UpdateSummaryCards(dt);
        }

        private void btnFilter_Click_1(object sender, EventArgs e)
        {
            FilterReports();
        }

        private void FilterReports()
        {
            try
            {
                using (SqlConnection con = new SqlConnection(connectionString))
                {
                    con.Open();

                    string query = @"
                    SELECT 
                        Id as 'ژمارە',
                        FuelType as 'جۆری سووتەمەنی',
                        Quantity as 'بڕی (لیتر)',
                        PricePerLiter as 'نرخی هەر لیترێک',
                        TotalAmount as 'کۆی گشتی',
                        CustomerName as 'ناوی کڕیار',
                        VehicleNumber as 'ژمارەی سەیارە',
                        SaleDate as 'بەرواری فرۆشتن'
                    FROM Sales 
                    WHERE SaleDate BETWEEN @from AND @to
                    ORDER BY SaleDate DESC";

                    SqlCommand cmd = new SqlCommand(query, con);
                    cmd.Parameters.AddWithValue("@from", dateFrom.Value);
                    cmd.Parameters.AddWithValue("@to", dateTo.Value.AddDays(1));

                    SqlDataAdapter adapter = new SqlDataAdapter(cmd);
                    DataTable dt = new DataTable();
                    adapter.Fill(dt);

                    dataGridView1.DataSource = dt;
                    CalculateTotals(dt);
                    UpdateSummaryCards(dt);
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"هەڵەی فلتەرکردن: {ex.Message}");
            }
        }

        private void btnPrint_Click_1(object sender, EventArgs e)
        {
            PrintReport();
        }

        private void PrintReport()
        {
            try
            {
                PrintDocument printDoc = new PrintDocument();
                printDoc.PrintPage += new PrintPageEventHandler(PrintReportPage);

                PrintPreviewDialog previewDialog = new PrintPreviewDialog();
                previewDialog.Document = printDoc;
                previewDialog.Text = "پێشبینینی ڕاپۆرت";
                previewDialog.WindowState = FormWindowState.Maximized;

                PageSetupDialog pageSetup = new PageSetupDialog();
                pageSetup.Document = printDoc;

                previewDialog.ShowDialog();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"هەڵە لە چاپکردنی ڕاپۆرت: {ex.Message}");
            }
        }

        private void PrintReportPage(object sender, PrintPageEventArgs e)
        {
            Graphics graphics = e.Graphics;
            Font titleFont = new Font("Arial", 18, FontStyle.Bold);
            Font headerFont = new Font("Arial", 12, FontStyle.Bold);
            Font normalFont = new Font("Arial", 10);
            Font smallFont = new Font("Arial", 9);

            float yPos = 50;
            float leftMargin = e.MarginBounds.Left;
            float rightMargin = e.MarginBounds.Right;
            float width = e.MarginBounds.Width;

            string title = "ڕاپۆرتی فرۆشتن - سیستمێکی بەڕێوەبردنی سووتەمەنی";
            SizeF titleSize = graphics.MeasureString(title, titleFont);
            graphics.DrawString(title, titleFont, Brushes.Navy,
                (width - titleSize.Width) / 2, yPos);
            yPos += titleSize.Height + 20;

            string reportDate = $"بەرواری ڕاپۆرت: {DateTime.Now:yyyy/MM/dd HH:mm}";
            graphics.DrawString(reportDate, headerFont, Brushes.Black, leftMargin, yPos);
            yPos += 30;

            string stats = $"کۆی فرۆشتن: {lblTotalSales.Text} | کۆی بڕ: {lblTotalQuantity.Text} | کۆی داھات: {lblTotalRevenue.Text}";
            graphics.DrawString(stats, headerFont, Brushes.DarkGreen, leftMargin, yPos);
            yPos += 40;

            graphics.DrawLine(new Pen(Color.Black, 2), leftMargin, yPos, rightMargin, yPos);
            yPos += 20;

            float[] columnWidths = { 60, 120, 80, 80, 100, 120, 100, 100 };
            string[] headers = { "ژمارە", "جۆری سووتەمەنی", "بڕی", "نرخ", "کۆی گشتی", "کڕیار", "سەیارە", "بەروار" };

            float xPos = leftMargin;
            for (int i = 0; i < headers.Length; i++)
            {
                graphics.DrawString(headers[i], headerFont, Brushes.White,
                    new RectangleF(xPos, yPos, columnWidths[i], 30));
                graphics.FillRectangle(Brushes.DarkBlue,
                    xPos, yPos, columnWidths[i], 30);
                xPos += columnWidths[i];
            }
            yPos += 35;

            DataTable data = (DataTable)dataGridView1.DataSource;
            if (data != null && data.Rows.Count > 0)
            {
                for (int i = 0; i < data.Rows.Count; i++)
                {
                    if (yPos > e.MarginBounds.Height - 100)
                    {
                        e.HasMorePages = true;
                        return;
                    }

                    DataRow row = data.Rows[i];
                    xPos = leftMargin;

                    string[] rowData = {
                        (i + 1).ToString(),
                        row["جۆری سووتەمەنی"].ToString(),
                        row["بڕی (لیتر)"].ToString(),
                        row["نرخی هەر لیترێک"].ToString() + " د.",
                        row["کۆی گشتی"].ToString() + " د.",
                        row["ناوی کڕیار"].ToString(),
                        row["ژمارەی سەیارە"].ToString(),
                        Convert.ToDateTime(row["بەرواری فرۆشتن"]).ToString("yyyy/MM/dd")
                    };

                    for (int j = 0; j < rowData.Length; j++)
                    {
                        Color bgColor = i % 2 == 0 ? Color.White : Color.FromArgb(240, 240, 240);
                        graphics.FillRectangle(new SolidBrush(bgColor),
                            xPos, yPos, columnWidths[j], 25);
                        graphics.DrawRectangle(Pens.LightGray, xPos, yPos, columnWidths[j], 25);

                        graphics.DrawString(rowData[j], normalFont, Brushes.Black,
                            new RectangleF(xPos + 2, yPos + 2, columnWidths[j] - 4, 21));

                        xPos += columnWidths[j];
                    }
                    yPos += 27;
                }
            }
            else
            {
                graphics.DrawString("هیچ داتایەک بۆ نیشاندان نیە", headerFont, Brushes.Red, leftMargin, yPos);
                yPos += 30;
            }

            yPos += 20;

            graphics.DrawLine(new Pen(Color.Black, 1), leftMargin, yPos, leftMargin + 200, yPos);
            yPos += 20;
            graphics.DrawString("واژۆی بەڕێوەبەر", headerFont, Brushes.Black, leftMargin, yPos);

            string pageNum = $"پەڕەی 1";
            graphics.DrawString(pageNum, normalFont, Brushes.Black, rightMargin - 50, e.MarginBounds.Bottom - 30);

            e.HasMorePages = false;
        }

