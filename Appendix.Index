public UserManagementForm()
{
    InitializeComponent();
    SetupBeautifulDesign();
    LoadAllUsers();
}

private void SetupBeautifulDesign()
{
    this.BackColor = Color.FromArgb(250, 250, 250);
    this.Text = "بەڕێوەبردنی بەکارهێنەران";

    dataGridViewUsers.BackgroundColor = Color.White;
    dataGridViewUsers.BorderStyle = BorderStyle.None;
    dataGridViewUsers.EnableHeadersVisualStyles = false;
    dataGridViewUsers.ColumnHeadersDefaultCellStyle.BackColor = Color.FromArgb(0, 123, 255);
    dataGridViewUsers.ColumnHeadersDefaultCellStyle.ForeColor = Color.White;
    dataGridViewUsers.ColumnHeadersDefaultCellStyle.Font = new Font("Arial", 10, FontStyle.Bold);
    dataGridViewUsers.AlternatingRowsDefaultCellStyle.BackColor = Color.FromArgb(240, 248, 255);
}

private void LoadAllUsers()
{
    try
    {
        using (SqlConnection con = new SqlConnection(connectionString))
        {
            con.Open();

            bool usersTableExists = CheckTableExists(con, "Users");

            if (!usersTableExists)
            {
                MessageBox.Show("هیچ خشتەی بەکارهێنەرێک نەدۆزرایەوە!\nتکایە خشتەکان دروست بکە.", "زانیاری", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            string query = @"
            SELECT 
                Username as 'ناوی بەکارهێنەر',
                Password as 'وشەی نهێنی'
            FROM Users
            ORDER BY Username";

            SqlDataAdapter adapter = new SqlDataAdapter(query, con);
            DataTable dt = new DataTable();
            adapter.Fill(dt);

            dataGridViewUsers.DataSource = dt;
            UpdateStatistics(dt);
            ApplyRowColors();

            if (dt.Rows.Count == 0)
            {
                MessageBox.Show("هیچ بەکارهێنەرێک نەدۆزرایەوە!", "زانیاری", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
        }
    }
    catch (Exception ex)
    {
        MessageBox.Show($"هەڵە لە بارکردنی داتا: {ex.Message}", "هەڵە", MessageBoxButtons.OK, MessageBoxIcon.Error);
    }
}

private bool CheckTableExists(SqlConnection connection, string tableName)
{
    try
    {
        SqlCommand cmd = new SqlCommand(
            $"SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME = '{tableName}'",
            connection);
        int count = (int)cmd.ExecuteScalar();
        return count > 0;
    }
    catch
    {
        return false;
    }
}

private void UpdateStatistics(DataTable dt)
{
    int totalUsers = dt.Rows.Count;

    lblTotalUsers.Text = $"کۆی گشتی: {totalUsers}";
    lblAdminsCount.Text = $"بەڕێوەبەر: 0";
    lblUsersCount.Text = $"کارمەند: {totalUsers}";
}

private void ApplyRowColors()
{
    foreach (DataGridViewRow row in dataGridViewUsers.Rows)
    {
        row.DefaultCellStyle.BackColor = Color.FromArgb(225, 245, 254);
        row.DefaultCellStyle.ForeColor = Color.FromArgb(1, 87, 155);
    }
}

