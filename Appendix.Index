        private void ViewFeedbackForm_Load(object sender, EventArgs e)
        {
            بارکردنی_فیدباکەکان();
            ڕێکخستنی_داتاگرید();
        }
        private void بارکردنی_فیدباکەکان()
        {
            
            try
            {
                using (SqlConnection con = new SqlConnection(connectionString))
                {
                    con.Open();
                    string query = @"SELECT * FROM Feedbacks WHERE IsApproved = 1 ORDER BY FeedbackDate DESC";
                    SqlDataAdapter adapter = new SqlDataAdapter(query, con);
                    DataTable dt = new DataTable();
                    adapter.Fill(dt);
                    dataGridView1.DataSource = dt;
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"هەڵە لە بارکردنی فیدباکەکان: {ex.Message}", "هەڵە");
            }
        }

        private void ڕێکخستنی_داتاگرید()
        {
            try
            {
                if (dataGridView1.Columns.Count > 0)
                {
                    if (dataGridView1.Columns.Contains("CustomerName"))
                    {
                        dataGridView1.Columns["CustomerName"].HeaderText = "ناوی کڕیار";
                        dataGridView1.Columns["CustomerName"].Width = 150;
                    }

                    if (dataGridView1.Columns.Contains("Rating"))
                    {
                        dataGridView1.Columns["Rating"].HeaderText = "هەڵسەنگاندن";
                        dataGridView1.Columns["Rating"].Width = 80;
                    }

                    if (dataGridView1.Columns.Contains("Comment"))
                    {
                        dataGridView1.Columns["Comment"].HeaderText = "بۆچوون";
                        dataGridView1.Columns["Comment"].Width = 250;
                    }

                    if (dataGridView1.Columns.Contains("ProductName"))
                    {
                        dataGridView1.Columns["ProductName"].HeaderText = "ناوی بەرهەم";
                        dataGridView1.Columns["ProductName"].Width = 120;
                    }

                    if (dataGridView1.Columns.Contains("FeedbackDate"))
                    {
                        dataGridView1.Columns["FeedbackDate"].HeaderText = "بەروار";
                        dataGridView1.Columns["FeedbackDate"].Width = 120;
                        dataGridView1.Columns["FeedbackDate"].DefaultCellStyle.Format = "yyyy/MM/dd HH:mm";
                    }

                    if (dataGridView1.Columns.Contains("Id"))
                        dataGridView1.Columns["Id"].Visible = false;

                    if (dataGridView1.Columns.Contains("Email"))
                        dataGridView1.Columns["Email"].Visible = false;

                    if (dataGridView1.Columns.Contains("IsApproved"))
                        dataGridView1.Columns["IsApproved"].Visible = false;
                }

                foreach (DataGridViewRow row in dataGridView1.Rows)
                {
                    if (row.Cells["Rating"].Value != null)
                    {
                        int rating = Convert.ToInt32(row.Cells["Rating"].Value);
                        if (rating == 5)
                            row.DefaultCellStyle.BackColor = System.Drawing.Color.LightGreen;
                        else if (rating == 4)
                            row.DefaultCellStyle.BackColor = System.Drawing.Color.LightBlue;
                        else if (rating == 3)
                            row.DefaultCellStyle.BackColor = System.Drawing.Color.LightYellow;
                        else if (rating <= 2)
                            row.DefaultCellStyle.BackColor = System.Drawing.Color.LightCoral;
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"هەڵە لە ڕێکخستنی داتاگرید: {ex.Message}", "هەڵە");
            }
        }

        private void btnRefresh_Click(object sender, EventArgs e)
        {
            بارکردنی_فیدباکەکان();
            ڕێکخستنی_داتاگرید();
        }

        private void btnSearch_Click(object sender, EventArgs e)
        {
            گەڕان(txtSearch.Text);
        private void btnSearch_KeyPress(object sender, KeyPressEventArgs e)
        {
            if (e.KeyChar == (char)Keys.Enter)
            {
                گەڕان(txtSearch.Text);
            }
        private void گەڕان(string searchText)
        {
            if (string.IsNullOrEmpty(searchText))
            {
                بارکردنی_فیدباکەکان();
                return;
            }
            try
            {
                using (SqlConnection con = new SqlConnection(connectionString))
                {
                    con.Open();
                    string query = @"SELECT * FROM Feedbacks 
                                   WHERE IsApproved = 1 AND 
                                         (CustomerName LIKE @Search OR Comment LIKE @Search OR ProductName LIKE @Search)
                                   ORDER BY FeedbackDate DESC";

                    SqlDataAdapter adapter = new SqlDataAdapter(query, con);
                    adapter.SelectCommand.Parameters.AddWithValue("@Search", "%" + searchText + "%");
                    DataTable dt = new DataTable();
                    adapter.Fill(dt);
                    dataGridView1.DataSource = dt;
                    ڕێکخستنی_داتاگرید();
                }
            catch (Exception ex)
            {
                MessageBox.Show($"هەڵە لە گەڕان: {ex.Message}", "هەڵە");
            }
        private void btnShowAll_Click(object sender, EventArgs e)
        {
            بارکردنی_فیدباکەکان();
            txtSearch.Clear();         } 















