        txtQuantity.Text = row.Cells["Quantity"].Value.ToString();
        txtPrice.Text = row.Cells["PricePerLiter"].Value.ToString();
        txtSupplier.Text = row.Cells["Supplier"].Value.ToString();
        dateEntry.Value = Convert.ToDateTime(row.Cells["EntryDate"].Value);
        btnAdd.Text = "نوێکردنەوە";
    }

