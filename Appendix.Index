        private void ApplyUserPermissions()
        {
            if (userType == "User")
            {
                
                btnAddFuel.Visible = false;
                guna2GradientButton3.Visible = false; 
                btnInventory.Visible = false;
                guna2GradientButton1.Visible = false;
                guna2GradientButton4.Visible = false;


                btnSales.Visible = true;
                btnSales.Location = new Point(300, 150);
                btnSales.Size = new Size(250, 60);
                btnSales.Font = new Font("Tahoma", 14F, FontStyle.Bold);
                btnSales.BackColor = Color.FromArgb(40, 167, 69); 
                btnSales.ForeColor = Color.White;

                
                lblTitle.Text = "بەخێربێیت - سیستمێکی فرۆشتن";
