public forget()
 {
     InitializeComponent();
     InitializeTimer();
 }
 
 private void forget_Load(object sender, EventArgs e)
 {
     WhatsAppService.ShowYourNumber();
     InitializeControls();
     UpdateControls();
     LoadUserTypes();
 }

 private void LoadUserTypes()
 {
     cmbUserType.Items.Add("بەڕێوەبەر");
     cmbUserType.Items.Add("کارمەند");
     cmbUserType.SelectedIndex = 0;
 }

 private void InitializeControls()
 {
     txtVerificationCode.Enabled = false;
     btnVerifyCode.Enabled = false;
     txtNewPassword.Enabled = false;
     txtConfirmPassword.Enabled = false;
     btnResetPassword.Enabled = false;
     lblTimer.Visible = false;
 }

 private void btnSendCode_Click(object sender, EventArgs e)
 {
     if (string.IsNullOrWhiteSpace(txtUsername.Text))
     {
         MessageBox.Show("❌ تکایە ناوی بەکارهێنەر بنووسە");
         return;
     }

     if (cmbUserType.SelectedIndex == -1)
     {
         MessageBox.Show("❌ تکایە جۆری بەکارهێنەر هەڵبژێرە");
         return;
     }

     username = txtUsername.Text.Trim();
     userType = cmbUserType.SelectedItem.ToString();


     if (!CheckUserExists(username, userType))
     {
         MessageBox.Show($"❌ ناوی بەکارهێنەر '{username}' بوونی نیە لە {userType}!\n\nتکایە پشکنینی بکە:\nبەڕێوەبەر: admin\nکارمەند: user");
         return;
     }

     
     GenerateVerificationCode();

     
     if (WhatsAppService.SendVerificationCode(verificationCode))
     {
         MessageBox.Show($"✅ کۆدی پشتڕاستکردنەوە دروست کرا!\nکۆد: {verificationCode}\n(لە ڕێکەوتی تاقیکردنەوە)");
         txtVerificationCode.Enabled = true;
         btnVerifyCode.Enabled = true;
         lblTimer.Visible = true;
         StartTimer();
         UpdateControls();
     }
     else
     {
         MessageBox.Show($"✅ کۆدی پشتڕاستکردنەوە دروست کرا!\nکۆد: {verificationCode}\n(لە ڕێکەوتی تاقیکردنەوە)");
         txtVerificationCode.Enabled = true;
         btnVerifyCode.Enabled = true;
         lblTimer.Visible = true;
         StartTimer();
         UpdateControls();
     }
 }


 private bool CheckUserExists(string username, string userType)
 
     try
     {
         using (SqlConnection con = new SqlConnection(connectionString))
         {
             con.Open();

             if (userType == "بەڕێوەبەر")
             {
                 
                 string[] adminTables = { "AdminTable", "AdminTb", "admin", "Admins" };

                 foreach (string table in adminTables)
                 {
                     if (CheckTableExists(con, table))
                     {
                         string adminQuery = $"SELECT COUNT(*) FROM {table} WHERE user = @username OR username = @username";
                         SqlCommand adminCmd = new SqlCommand(adminQuery, con);
                         adminCmd.Parameters.AddWithValue("@username", username);

                         int count = (int)adminCmd.ExecuteScalar();
                         if (count > 0)
                         {
                             return true;
                         }
                     }
                 }
                 return false;
             }
             else if (userType == "کارمەند")
             {
                 if (CheckTableExists(con, "Users"))
                 {
                     string userQuery = "SELECT COUNT(*) FROM Users WHERE Username = @username";
                     SqlCommand userCmd = new SqlCommand(userQuery, con);
                     userCmd.Parameters.AddWithValue("@username", username);
                     return (int)userCmd.ExecuteScalar() > 0;
                 }
                 return false;
             }
             return false;
         }
     }
     catch (Exception ex)
     {
         MessageBox.Show($"هەڵە لە پشکنینی بەکارهێنەر: {ex.Message}");
         return false;
     }
 }

 private bool CheckTableExists(SqlConnection connection, string tableName)
 {
     try
     {
         SqlCommand cmd = new SqlCommand(
             $"SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME = '{tableName}'",
             connection);
         int count = (int)cmd.ExecuteScalar();
         return count > 0;
     }
     catch
     {
         return false;
     }
 }

 private void btnVerifyCode_Click(object sender, EventArgs e)
 {
     if (string.IsNullOrWhiteSpace(txtVerificationCode.Text))
     {
         MessageBox.Show("❌ تکایە کۆدی پشتڕاستکردنەوە بنووسە");
         return;
     }

     if (VerifyCode())
     {
         MessageBox.Show("✅ پشتڕاستکردنەوە سەرکەوتوو بوو! ئێستا دەتوانیت وشەی نهێنی نوێ بنووسیت.");
         txtNewPassword.Enabled = true;
         txtConfirmPassword.Enabled = true;
         btnResetPassword.Enabled = true;
         UpdateControls();
     }
     else
     {
         MessageBox.Show("❌ کۆدی پشتڕاستکردنەوە هەڵەیە یان کاتی تیاچوون!");
     }
 }

 private void btnResetPassword_Click(object sender, EventArgs e)
 {
     if (ResetPassword())
     {
         MessageBox.Show("✅ گۆڕینی وشەی نهێنی سەرکەوتوو بوو!");
         this.Close();
     }
 }

 private void btnResendCode_Click(object sender, EventArgs e)
 {
     btnSendCode_Click(sender, e);
 }

 private void GenerateVerificationCode()
 {
     Random random = new Random();
     verificationCode = random.Next(100000, 999999).ToString();
     codeExpiry = DateTime.Now.AddMinutes(10);
 }

 private bool VerifyCode()
 {
     return txtVerificationCode.Text == verificationCode && DateTime.Now <= codeExpiry;
 }

 private bool ResetPassword()
 {
     if (string.IsNullOrWhiteSpace(txtNewPassword.Text))
     {
         MessageBox.Show("❌ تکایە وشەی نهێنی نوێ بنووسە");
         return false;
     }

     if (txtNewPassword.Text != txtConfirmPassword.Text)
     {
         MessageBox.Show("❌ وشەی نهێنی یەک ناگرێتەوە!");
         return false;
     }

     if (txtNewPassword.Text.Length < 4)
     {
         MessageBox.Show("❌ وشەی نهێنی دەبێت بەلایەنی کەمەوە 4 پیت بێت!");
         return false;
     }

     return UpdatePasswordInDatabase(username, userType, txtNewPassword.Text);
 }

 private bool UpdatePasswordInDatabase(string username, string userType, string newPassword)
 {
     try
     {
         using (SqlConnection con = new SqlConnection(connectionString))
         {
             con.Open();

             if (userType == "بەڕێوەبەر")
             {
                 
                 string[] adminTables = { "AdminTable", "AdminTb", "admin" };

                 foreach (string table in adminTables)
                 {
                     if (CheckTableExists(con, table))
                     {
                         
                         string[] passwordColumns = { "pass", "pass", "pass" };
                         string[] userColumns = { "user", "user", "user" };

                         foreach (string passCol in passwordColumns)
                         {
                             foreach (string userCol in userColumns)
                             {
                                 try
                                 {
                                     string adminQuery = $"UPDATE {table} SET {passCol} = @password WHERE {userCol} = @username";
                                     SqlCommand adminCmd = new SqlCommand(adminQuery,con)    adminCmd.Parameters.AddWithValue("@password", newPassword);                                     adminCmd.Parameters.AddWithValue("@username", username);

                                     int rowsAffected = adminCmd.ExecuteNonQuery();
                                     if (rowsAffected > 0)
                                     {
                                         return true;
                                     }
                                 }
                                 catch
                                 {
                                     
                                     continue;
                                 }
                             }
                         }
                     }
                 }
                 return false;
             }
             else if (userType == "کارمەند")
             {
                 if (CheckTableExists(con, "Users"))
                 {
                     string userQuery = "UPDATE Users SET Password = @password WHERE Username = @username";
                     SqlCommand userCmd = new SqlCommand(userQuery, con);
                     userCmd.Parameters.AddWithValue("@password", newPassword);
                     userCmd.Parameters.AddWithValue("@username", username);
                     return userCmd.ExecuteNonQuery() > 0;
                 }
                 return false;
             }

             return false;
         }
     }
     catch (Exception ex)
     {
         MessageBox.Show($"هەڵە لە نوێکردنەوەی وشەی نهێنی: {ex.Message}");
         return false;
     }
 }

 private void InitializeTimer()
 {
     timer = new Timer();
     timer.Interval = 1000;
     timer.Tick += Timer_Tick;
 }

 private void StartTimer()
 {
     timer.Start();
 }

 private void Timer_Tick(object sender, EventArgs e)
 {
     TimeSpan remaining = codeExpiry - DateTime.Now;

     if (remaining.TotalSeconds > 0)
     {
         lblTimer.Text = $"⏰ کات ماوە: {remaining:mm\\:ss}";
     }
     else
     {
         lblTimer.Text = "⏰ کۆدەکە بەسەرچووە!";
         txtVerificationCode.Enabled = false;
         btnVerifyCode.Enabled = false;
         timer.Stop();
     }
 }

 private void UpdateControls()
 {
     bool codeSent = !string.IsNullOrEmpty(verificationCode);
     bool codeVerified = codeSent && VerifyCode();

     if (codeSent && !codeVerified)
     {
         txtVerificationCode.Enabled = true;
         btnVerifyCode.Enabled = true;
         lblTimer.Visible = true;
         txtNewPassword.Enabled = false;
         txtConfirmPassword.Enabled = false;
         btnResetPassword.Enabled = false;
     }
     else if (codeVerified)
     {
         txtVerificationCode.Enabled = false;
         btnVerifyCode.Enabled = false;
         txtNewPassword.Enabled = true;
         txtConfirmPassword.Enabled = true;
         btnResetPassword.Enabled = true;
         lblTimer.Visible = false;
     }
     else
     {
         txtVerificationCode.Enabled = false;
         btnVerifyCode.Enabled = false;
         txtNewPassword.Enabled = false;
         txtConfirmPassword.Enabled = false;
         btnResetPassword.Enabled = false;
         lblTimer.Visible = false;
     }
 }
private void btnCheckDatabase_Click(object sender, EventArgs e)
 {
     CheckAndCreateDatabase();
 }

 private void CheckAndCreateDatabase()
 {
     try
     {
         using (SqlConnection con = new SqlConnection(connectionString))
         {
             con.Open();

             string message = "خشتەکانی بنکەی دراوە:\n\n";

             string query = "SELECT name FROM sys.tables ORDER BY name";
             SqlCommand cmd = new SqlCommand(query, con);
             SqlDataReader dr = cmd.ExecuteReader();
          bool hasTables = false;
             while (dr.Read())
             {
                 message += $"• {dr["name"]}\n";
                 hasTables = true;
             }
             dr.Close();

             if (!hasTables)
             {
                 message += "❌ هیچ خشتەیەک نەدۆزرایەوە!\n";
                  
                 if (MessageBox.Show("ئایا دەتەوێت خشتەی بنچینەی دروست بکەیت؟", "دروستکردنی خشتە", MessageBoxButtons.YesNo) == DialogResult.Yes)
                 {
                     CreateDefaultTables(con);
                 }
             }

             MessageBox.Show(message, "خشتەکان");
         }
     }
     catch (Exception ex)
     {
         MessageBox.Show($"هەڵە لە پشکنینی بنکەی دراوە: {ex.Message}");
     }
 }

 private void CreateDefaultTables(SqlConnection con)
 {
     try
       
         string createAdminTable = @"
         IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='AdminTable' AND xtype='U')
         CREATE TABLE AdminTable (
             id INT PRIMARY KEY IDENTITY(1,1),
             user NVARCHAR(50) NOT NULL,
             pass NVARCHAR(100) NOT NULL
         )";

         SqlCommand cmd1 = new SqlCommand(createAdminTable, con);
         cmd1.ExecuteNonQuery();

         string insertAdmin = @"
         IF NOT EXISTS (SELECT * FROM AdminTable WHERE user = 'admin')
         INSERT INTO AdminTable (user, pass) VALUES ('admin', '123456')";

         SqlCommand cmd2 = new SqlCommand(insertAdmin, con);
         cmd2.ExecuteNonQuery();

         string createUsersTable = @"
         IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='Users' AND xtype='U')
         CREATE TABLE Users (
             Id INT PRIMARY KEY IDENTITY(1,1),
             Username NVARCHAR(50) NOT NULL,
             Password NVARCHAR(100) NOT NULL
         )";

         SqlCommand cmd3 = new SqlCommand(createUsersTable, con);
         cmd3.ExecuteNonQuery();

         
         string insertUser = @"
         IF NOT EXISTS (SELECT * FROM Users WHERE Username = 'user')
         INSERT INTO Users (Username, Password) VALUES ('user', '123456')";

         SqlCommand cmd4 = new SqlCommand(insertUser, con);
         cmd4.ExecuteNonQuery();

         MessageBox.Show("✅ خشتەکان دروست کران!\n\n" +
                       "بەڕێوەبەر:\nناوی بەکارهێنەر: admin\nوشەی نهێنی: 123456\n\n" +
                       "کارمەند:\nناوی بەکارهێنەر: user\nوشەی نهێنی: 123456");
     }
     catch (Exception ex)
     {
         MessageBox.Show($"❌ هەڵە لە دروستکردنی خشتە: {ex.Message}");
     }
 }
 
•	The sales process

        public SalesForm(string userType)
        {
            InitializeComponent();
            this.userType = userType;
            LoadFuelTypes();
            SetupForm();
            InitializePaymentSection();
            InitializePrintDocument();
        }

        private void SetupForm()
        {
            txtQuantity.Enabled = false;
            txtCustomer.Enabled = false;
            txtVehicle.Enabled = false;
            btnSell.Enabled = false;

            lblAvailableQuantity.Text = " 0 لیتر";
            lblPriceInfo.Text = "نرخ: 0 دینار";
            lblMessage.Text = "تکایە جۆری سووتەمەنی هەڵبژێرە";
            lblMessage.ForeColor = Color.Blue;
        }

        private void InitializePaymentSection()
        {
            rbtnCash.Checked = true;
            paymentMethod = "پارەی نەختی";
            panelBarcode.Visible = false;
            btnScanBarcode.Enabled = false;
        }

        private void InitializePrintDocument()
        {
            printDocument = new PrintDocument();
            printDocument.PrintPage += new PrintPageEventHandler(PrintReceiptPage);
        }

        private void LoadFuelTypes()
        {
            try
            {
                using (SqlConnection con = new SqlConnection(connectionString))
                {
                    con.Open();

                    string query = "SELECT DISTINCT FuelType FROM Products WHERE Quantity > 0";
                    SqlCommand cmd = new SqlCommand(query, con);
                    SqlDataReader reader = cmd.ExecuteReader();

                    cmbFuelType.Items.Clear();
                    while (reader.Read())
                    {
                        cmbFuelType.Items.Add(reader["FuelType"].ToString());
                    }
                    reader.Close();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("هەڵە لە بارکردنی جۆرەکانی سووتەمەنی: " + ex.Message);
            }
        }

        private void cmbFuelType_SelectedIndexChanged(object sender, EventArgs e)
        {
            if (cmbFuelType.SelectedItem != null)
            {
                string selectedFuel = cmbFuelType.SelectedItem.ToString();
                LoadFuelDetails(selectedFuel);
            }
        }

        private void LoadFuelDetails(string fuelType)
        {
            try
            {
                using (SqlConnection con = new SqlConnection(connectionString))
                {
                    con.Open();

                    string query = "SELECT PricePerLiter, Quantity FROM Products WHERE FuelType = @FuelType";
                    SqlCommand cmd = new SqlCommand(query, con);
                    cmd.Parameters.AddWithValue("@FuelType", fuelType);

                    SqlDataReader reader = cmd.ExecuteReader();

                    if (reader.Read())
                    {
                        decimal price = Convert.ToDecimal(reader["PricePerLiter"]);
                        decimal quantity = Convert.ToDecimal(reader["Quantity"]);

                        txtPrice.Text = price.ToString("N2");
                        lblAvailableQuantity.Text = "بڕ: " + quantity.ToString("N2") + " لیتر";
                        lblPriceInfo.Text = "نرخ: " + price.ToString("N2") + " دینار";

                        txtQuantity.Enabled = true;
                        txtCustomer.Enabled = true;
                        txtVehicle.Enabled = true;

                        lblMessage.Text = "دەتوانیت فرۆشتن بکەیت";
                        lblMessage.ForeColor = Color.Green;

                        panelPayment.Enabled = true;
                        btnScanBarcode.Enabled = true;
                        CheckIfReadyToSell();
                    }
                    reader.Close();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("هەڵە لە بارکردنی زانیاریی سووتەمەنی: " + ex.Message);
            }
        }

        private void txtQuantity_TextChanged(object sender, EventArgs e)
        {
            CalculateTotal();
            CheckQuantity();
            CheckIfReadyToSell();
        }

        private void txtPrice_TextChanged(object sender, EventArgs e)
        {
            CalculateTotal();
            CheckIfReadyToSell();
        }

        private void txtCustomer_TextChanged(object sender, EventArgs e)
        {
            CheckIfReadyToSell();
        }

        private void CheckQuantity()
        {
            if (cmbFuelType.SelectedItem == null) return;

            if (decimal.TryParse(txtQuantity.Text, out decimal requestedQuantity))
            {
                string availableText = lblAvailableQuantity.Text.Replace("بڕ:", "").Replace("لیتر", "").Trim();
                if (decimal.TryParse(availableText, out decimal availableQuantity))
                {
                    if (requestedQuantity > availableQuantity)
                    {
                        lblMessage.Text = "ئەم بڕە لە کەل و پەلدا نیە! (ماوە: " + availableQuantity.ToString("N2") + " لیتر)";
                        lblMessage.ForeColor = Color.Red;
                    }
                    else if (requestedQuantity <= 0)
                    {
                        lblMessage.Text = "بڕەکە دەبێت زیاتر بێت لە سفر!";
                        lblMessage.ForeColor = Color.Red;
                    }
                    else
                    {
                        lblMessage.Text = "بڕەکە بەردەستە";
                        lblMessage.ForeColor = Color.Green;
                    }
                }
            }
            else if (!string.IsNullOrEmpty(txtQuantity.Text))
            {
                lblMessage.Text = "تکایە بڕەکە بە شێوەیەکی ڕاست بنووسە!";
                lblMessage.ForeColor = Color.Red;
            }
        }

        private void CalculateTotal()
        {
            if (decimal.TryParse(txtQuantity.Text, out decimal quantity) &&
                decimal.TryParse(txtPrice.Text, out decimal price))
            {
                decimal total = quantity * price;
                lblTotal.Text = total.ToString("N2") + " دینار";
            }
            else
            {
                lblTotal.Text = "0.00 دینار";
            }
        }

        private void rbtnCash_CheckedChanged_1(object sender, EventArgs e)
        {
            if (rbtnCash.Checked)
            {
                paymentMethod = "نقد";
                panelBarcode.Visible = false;
                btnScanBarcode.Enabled = true;
                CheckIfReadyToSell();
            }
        }

        private void rbtnCard_CheckedChanged_1(object sender, EventArgs e)
        {
            if (rbtnCard.Checked)
            {
                paymentMethod = "کارت";
                panelBarcode.Visible = true;
                txtBarcode.Focus();
                btnScanBarcode.Enabled = true;
                CheckIfReadyToSell();
            }
        }

        private void CheckIfReadyToSell()
        {
            bool isFuelSelected = cmbFuelType.SelectedItem != null;
            bool isQuantityValid = decimal.TryParse(txtQuantity.Text, out decimal qty) && qty > 0;
            bool isCustomerEntered = !string.IsNullOrWhiteSpace(txtCustomer.Text);
            bool isPaymentSelected = !string.IsNullOrEmpty(paymentMethod);
            bool isCardBarcodeValid = true;

            if (paymentMethod == "کارت")
            {
                isCardBarcodeValid = !string.IsNullOrWhiteSpace(txtBarcode.Text);
            }

            btnSell.Enabled = isFuelSelected && isQuantityValid && isCustomerEntered && isPaymentSelected && isCardBarcodeValid;
        }

        private void txtBarcode_TextChanged_1(object sender, EventArgs e)
        {
            barcodeNumber = txtBarcode.Text;
            CheckIfReadyToSell();
        }

        private void btnScanBarcode_Click(object sender, EventArgs e)
        {
            if (paymentMethod == "کارت")
            {
                ProcessCardPayment();
            }
            else if (paymentMethod == "نقد")
            {
                ProcessCashPayment();
            }
        }

        private void ProcessCardPayment()
        {
            using (CardPaymentForm cardForm = new CardPaymentForm())
            {
                if (cardForm.ShowDialog() == DialogResult.OK)
                {
                    txtBarcode.Text = $"کارت-{DateTime.Now:HHmmss}";
                    barcodeNumber = txtBarcode.Text;
                    MessageBox.Show("پارەدانی کارت سەرکەوتوو بوو!", "سەرکەوتوو");
                }
            }
        }

        private void ProcessCashPayment()
        {
            txtBarcode.Text = $"نقد-{DateTime.Now:HHmmss}";
            barcodeNumber = txtBarcode.Text;
            MessageBox.Show("بارکۆدی نقد دروست کرا!", "نقد");
        }

        private void btnSell_Click_1(object sender, EventArgs e)
        {
            if (ValidateSale())
            {
                ProcessSale();
            }
        private bool ValidateSale()
        {
            if (cmbFuelType.SelectedIndex == -1)
            {
                MessageBox.Show("تکایە جۆری سووتەمەنی هەڵبژێرە");
                return false;
            }

            if (string.IsNullOrEmpty(txtQuantity.Text) || !decimal.TryParse(txtQuantity.Text, out decimal quantity))
            {
                MessageBox.Show("تکایە بڕی سووتەمەنی بنووسە بە شێوەیەکی دروست");
                return false;
            }

            if (string.IsNullOrWhiteSpace(txtCustomer.Text))
            {
                MessageBox.Show("تکایە ناوی کڕیار بنووسە");
                return false;
            }

            if (string.IsNullOrEmpty(paymentMethod))
            {
                MessageBox.Show("تکایە شێوازی پارەدان هەڵبژێرە");
                return false;
            }

            if (paymentMethod == "کارت" && string.IsNullOrWhiteSpace(txtBarcode.Text))
            {
                MessageBox.Show("تکایە بارکۆدەکە بخوێنەرەوە یان دووگمەی سکانکردن کرتە بکە");
                return false;
            }
            string availableText = lblAvailableQuantity.Text.Replace("کەل و پەل:", "").Replace("لیتر", "").Trim();
            if (decimal.TryParse(availableText, out decimal availableQuantity))
            {
                if (quantity > availableQuantity)
                {
                    MessageBox.Show("بڕەکە زیاترە لە ئەوەی لە کەل و پەلدا هەیە! کەل و پەل: " + availableQuantity.ToString("N2") + " لیتر");
                    return false;
            return true;
        }

        private void ProcessSale()
        {
            try
            {
                using (SqlConnection con = new SqlConnection(connectionString))
                {
                    con.Open();
                   SqlTransaction transaction = con.BeginTransaction();

                    try
                    {
                        currentFuelType = cmbFuelType.SelectedItem.ToString();
                        currentQuantity = decimal.Parse(txtQuantity.Text);
                        currentPrice = decimal.Parse(txtPrice.Text);
                        currentTotal = currentQuantity * currentPrice;
                        currentCustomer = txtCustomer.Text;
                        currentVehicle = txtVehicle.Text;

                        string updateInventoryQuery = @" UPDATE Products 
                        SET Quantity = Quantity - @Quantity 
                        WHERE FuelType = @FuelType AND Quantity >= @Quantity";

                        SqlCommand updateCmd = new SqlCommand(updateInventoryQuery, con, transaction);
                        updateCmd.Parameters.AddWithValue("@Quantity", currentQuantity);
                        updateCmd.Parameters.AddWithValue("@FuelType", currentFuelType);

                        int inventoryResult = updateCmd.ExecuteNonQuery();

                        if (inventoryResult == 0)
                        {
                            throw new Exception("کەل و پەل بە سەرکەوتوویی نوێ نەکرایەوە!");
                        }
                        string insertSaleQuery = @"
                        INSERT INTO Sales (FuelType, Quantity, PricePerLiter, TotalAmount, 
                                          CustomerName, VehicleNumber,SaleDate  ) 
                        VALUES (@FuelType, @Quantity, @Price, @Total, @Customer, @Vehicle,   @SaleDate )";

  SqlCommand saleCmd = new SqlCommand(insertSaleQuery, con, transaction);
  saleCmd.Parameters.AddWithValue("@FuelType", currentFuelType);
     saleCmd.Parameters.AddWithValue("@Quantity", currentQuantity);
      saleCmd.Parameters.AddWithValue("@Price", currentPrice);
       saleCmd.Parameters.AddWithValue("@Total", currentTotal);
        saleCmd.Parameters.AddWithValue("@Customer", currentCustomer);
        saleCmd.Parameters.AddWithValue("@Vehicle", currentVehicle);
saleCmd.Parameters.AddWithValue("@PaymentMethod", paymentMethod);  saleCmd.Parameters.AddWithValue("@Barcode", barcodeNumber ?? "");*/  saleCmd.Parameters.AddWithValue("@SaleDate", DateTime.Now);
                        int saleResult = saleCmd.ExecuteNonQuery();
                        if (saleResult > 0)
                        {
                            transaction.Commit();
                            ShowSuccessMessage();
                            PrintReceiptNow();
                            ResetForm();
                    catch (Exception ex)
                    {
                        transaction.Rollback();
                        throw new Exception("هەڵە لە پرۆسەی فرۆشتن: " + ex.Message);            catch (Exception ex)
            {
                MessageBox.Show("❌ هەڵە: " + ex.Message, "هەڵە", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void ShowSuccessMessage()
        {
            MessageBox.Show("✅ فرۆشتنەکە بە سەرکەوتوویی تەواو بوو!\n\n" +
                          "جۆری سووتەمەنی: " + currentFuelType +
                          "\nبڕ: " + currentQuantity.ToString("N2") + " لیتر" +
                          "\nکۆی گشتی: " + currentTotal.ToString("N2") + " دینار" +
                          "\nکڕیار: " + currentCustomer +
                          "\nشێوازی پارەدان: " + paymentMethod,
                          "سەرکەوتوو", MessageBoxButtons.OK, MessageBoxIcon.Information);
        }

        private void PrintReceiptNow()
        {
            try
            {
                PrintPreviewDialog preview = new PrintPreviewDialog();
                preview.Document = printDocument;
                preview.Text = "پێشبینینی پەسەندەر";
                preview.WindowState = FormWindowState.Maximized;
                preview.ShowDialog();
            }
            catch (Exception ex)
            {
                MessageBox.Show("هەڵە لە پێشبینینی پەسەندەر: " + ex.Message);
            }
        }

        private void PrintReceiptPage(object sender, PrintPageEventArgs e)
        {
            Graphics g = e.Graphics;
            Font titleFont = new Font("Arial", 20, FontStyle.Bold);
            Font headerFont = new Font("Arial", 12, FontStyle.Bold);
            Font normalFont = new Font("Arial", 10);
            Font smallFont = new Font("Arial", 9);

            float yPos = 50;
            float center = e.MarginBounds.Width / 2;

        g.DrawString("پەسەندەری فرۆشتن", titleFont, Brushes.DarkBlue, center - 100, yPos);
            yPos += 40;

            g.DrawString("وێستگەی سووتەمەنی", headerFont, Brushes.Black, center - 80, yPos);
            yPos += 25;
            g.DrawString("تەلەفۆن: ٠٧٧٠ ١٢٣ ٤٥٦٧", normalFont, Brushes.Black, center - 70, yPos);
            yPos += 40;

            g.DrawLine(Pens.Black, 50, yPos, e.MarginBounds.Width - 50, yPos);
            yPos += 20;

            g.DrawString("ناوی کڕیار:", headerFont, Brushes.Black, 50, yPos);
            g.DrawString(currentCustomer, normalFont, Brushes.Black, 200, yPos);
            yPos += 25;

            g.DrawString("ژمارەی سەیارە:", headerFont, Brushes.Black, 50, yPos);
            g.DrawString(currentVehicle, normalFont, Brushes.Black, 200, yPos);
            yPos += 25;

            g.DrawString("جۆری سووتەمەنی:", headerFont, Brushes.Black, 50, yPos);
            g.DrawString(currentFuelType, normalFont, Brushes.Black, 200, yPos);
            yPos += 25;

            g.DrawString("بڕ (لیتر):", headerFont, Brushes.Black, 50, yPos);
            g.DrawString(currentQuantity.ToString("N2"), normalFont, Brushes.Black, 200, yPos);
            yPos += 25;

            g.DrawString("نرخ:", headerFont, Brushes.Black, 50, yPos);
            g.DrawString(currentPrice.ToString("N2") + " دینار", normalFont, Brushes.Black, 200, yPos);
            yPos += 25;

            g.DrawString("کۆی گشتی:", headerFont, Brushes.Black, 50, yPos);
            g.DrawString(currentTotal.ToString("N2") + " دینار", normalFont, Brushes.Black, 200, yPos);
            yPos += 25;

            g.DrawString("شێوازی پارەدان:", headerFont, Brushes.Black, 50, yPos);
            g.DrawString(paymentMethod, normalFont, Brushes.Black, 200, yPos);
            yPos += 25;

            if (paymentMethod == "کارت")
            {
                g.DrawString("ژمارەی کارت:", headerFont, Brushes.Black, 50, yPos);
                g.DrawString(barcodeNumber, normalFont, Brushes.Black, 200, yPos);
                yPos += 25;
            }

            g.DrawString("بەروار:", headerFont, Brushes.Black, 50, yPos);
            g.DrawString(DateTime.Now.ToString("yyyy/MM/dd HH:mm"), normalFont, Brushes.Black, 200, yPos);
            yPos += 40;

            g.DrawLine(Pens.Black, 50, yPos, e.MarginBounds.Width - 50, yPos);
            yPos += 20;

            g.DrawString("سوپاس بۆ داواکاریەکەت! ✨", headerFont, Brushes.DarkGreen, center - 100, yPos);
            yPos += 40;

            g.DrawString("واژۆی کارمەند", headerFont, Brushes.Black, center - 60, yPos);
            yPos += 20;
            g.DrawLine(Pens.Black, center - 80, yPos, center + 80, yPos);

            string receiptNo = "RN" + DateTime.Now.ToString("yyyyMMddHHmmss");
            g.DrawString("ژمارەی پەسەندەر: " + receiptNo, smallFont, Brushes.Black, 50, e.MarginBounds.Bottom - 30);
        }

        private void ResetForm()
        {
            cmbFuelType.SelectedIndex = -1;
            txtQuantity.Clear();
            txtCustomer.Clear();
            txtVehicle.Clear();
            txtPrice.Clear();
            txtBarcode.Clear();
            lblTotal.Text = "0.00 دینار";
            lblAvailableQuantity.Text = ": 0 لیتر";
            lblPriceInfo.Text = "نرخ: 0 دینار";
            lblMessage.Text = "تکایە جۆری سووتەمەنی هەڵبژێرە";
            lblMessage.ForeColor = Color.Blue;

            rbtnCash.Checked = true;
            panelBarcode.Visible = false;
            paymentMethod = "نقد";
            barcodeNumber = "";

            txtQuantity.Enabled = false;
            txtCustomer.Enabled = false;
            txtVehicle.Enabled = false;
            btnSell.Enabled = false;
            btnScanBarcode.Enabled = false;

            LoadFuelTypes();
        }

